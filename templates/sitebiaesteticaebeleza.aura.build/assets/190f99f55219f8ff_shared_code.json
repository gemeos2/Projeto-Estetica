=\"absolute inset-0 z-0 overflow-hidden\">\n            <img src=\"https://images.unsplash.com/photo-1616394584738-fc6e612e71b9?q=80&w=2070&auto=format&fit=crop\" \n                 class=\"hero-img w-full h-full object-cover object-center grayscale mix-blend-luminosity opacity-40 brightness-75 contrast-125\" \n                 alt=\"Hero Background\">\n            <div class=\"absolute inset-0 bg-gradient-to-t from-[#050505] via-[#050505]/40 to-[#050505]/80\"></div>\n        </div>\n\n        <div class=\"hero-content-inner w-full h-full flex flex-col justify-between relative z-20\">\n            <!-- Header Area -->\n            <header class=\"w-full px-6 py-8 md:px-12 flex justify-between items-center\">\n                <div class=\"hero-brand font-display font-normal text-xl tracking-tight text-[#EFE4D9]\">Bia Estética</div>\n            </header>\n\n            <!-- Main Content Grid -->\n            <div class=\"flex-grow w-full px-6 md:px-12 flex flex-col justify-center gap-16 lg:gap-0 lg:grid lg:grid-cols-12 lg:items-center\">\n                \n                <!-- Left Column -->\n                <div class=\"lg:col-span-7 flex flex-col items-start gap-8 lg:-mt-24\">\n                    <h1 class=\"hero-headline font-display font-light text-4xl md:text-5xl lg:text-7xl leading-[1.05] tracking-tight max-w-3xl text-[#EFE4D9]\">\n                        Realçando sua beleza com método, experiência e sensibilidade\n                    </h1>\n                    <div class=\"hero-cta overflow-hidden mt-4\">\n                        <a href=\"https://wa.me/5521993350822\" target=\"_blank\" class=\"inline-flex items-center gap-3 bg-[#EFE4D9] text-[#2A3B34] px-8 py-4 rounded-full text-base font-light hover:bg-[#DDA7A5] hover:text-[#050505] transition-colors duration-300\">\n                            Agendar avaliação\n                            <iconify-icon icon=\"solar:arrow-right-linear\" class=\"text-xl\"></iconify-icon>\n                        </a>\n                    </div>\n                </div>\n\n                <!-- Right Column -->\n                <div class=\"lg:col-span-4 lg:col-start-9 flex flex-col items-start lg:items-end gap-3 font-display font-light text-lg md:text-xl tracking-tight lg:-mt-24 text-[#EFE4D9]/80 text-left lg:text-right\">\n                    <a href=\"#servicos\" class=\"hero-link hover:text-[#DDA7A5] hover:translate-x-1 lg:hover:-translate-x-1 transition-all\">Estratégia facial & corporal</a>\n                    <a href=\"#servicos\" class=\"hero-link hover:text-[#DDA7A5] hover:translate-x-1 lg:hover:-translate-x-1 transition-all\">Protocolos personalizados</a>\n                    <a href=\"#servicos\" class=\"hero-link hover:text-[#DDA7A5] hover:translate-x-1 lg:hover:-translate-x-1 transition-all\">Depilação a laser</a>\n                    <a href=\"#servicos\" class=\"hero-link hover:text-[#DDA7A5] hover:translate-x-1 lg:hover:-translate-x-1 transition-all\">Design de olhar</a>\n                    <a href=\"#servicos\" class=\"hero-link hover:text-[#DDA7A5] hover:translate-x-1 lg:hover:-translate-x-1 transition-all\">Maquiagem</a>\n                </div>\n            </div>\n\n            <!-- Huge Bottom Text -->\n            <div class=\"w-full px-6 md:px-12 overflow-hidden flex justify-center lg:justify-start pb-24 md:pb-32 lg:pb-40\">\n                <h2 class=\"hero-huge-text font-display font-normal text-[16vw] leading-[0.75] tracking-tighter w-full text-center lg:text-left text-[#EFE4D9] select-none\">\n                    Bia Estética<span class=\"text-[#DDA7A5]\">.</span>\n                </h2>\n            </div>\n        </div>\n    </section>\n\n    <!-- Main Scrollable Wrapper for Reveal Effect -->\n    <main class=\"content-wrapper relative z-10 w-full mt-[100dvh] bg-[#EFE4D9] rounded-t-[3rem] shadow-[0_-30px_60px_rgba(0,0,0,0.6)] overflow-hidden\">\n        \n        <!-- Método B.I.A -->\n        <section class=\"px-4 md:px-12 lg:px-24 pt-32 md:pt-40 pb-24 md:pb-32 w-full mx-auto relative bg-[#EFE4D9]\">\n            <div class=\"max-w-7xl mx-auto\">\n                <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-12 items-start\">\n                    \n                    <!-- Left: Sticky Intro -->\n                    <div class=\"lg:col-span-5 lg:sticky lg:top-32 gs-reveal\">\n                        <span class=\"font-mono text-xs uppercase tracking-tight text-[#5C8A79] mb-6 block\">O Método</span>\n                        <h2 class=\"font-display text-4xl md:text-5xl lg:text-6xl tracking-tight leading-[1] text-[#2A3B34] font-normal mb-8\">Método B.I.A.<br><span class=\"text-[#2A3B34]/40 text-3xl md:text-4xl lg:text-5xl mt-2 block\">O jeito Bia de cuidar da sua beleza</span></h2>\n                        <p class=\"font-sans text-lg md:text-xl font-light leading-relaxed text-[#2A3B34]/70 mb-8\">\n                            A primeira sessão não é apenas um atendimento.<br><br>É o início de uma jornada pensada para compreender suas necessidades, estruturar prioridades e construir um cuidado estético mais inteligente, personalizado e eficaz.\n                        </p>\n                    </div>\n\n                    <!-- Right: Scrolling Content -->\n                    <div class=\"lg:col-span-6 lg:col-start-7 flex flex-col gap-12 md:gap-20\">\n                        \n                        <!-- B -->\n                        <div class=\"group border-t border-[#2A3B34]/10 pt-10 gs-reveal-up\">\n                            <div class=\"flex items-baseline gap-6 mb-6\">\n                                <span class=\"font-display text-5xl md:text-7xl text-[#DDA7A5] font-light leading-none\">B.</span>\n                                <h3 class=\"font-display text-2xl md:text-3xl text-[#2A3B34] font-normal tracking-tight\">Base de Beleza</h3>\n                            </div>\n                            <p class=\"font-sans text-lg font-light leading-relaxed text-[#2A3B34]/70\">\n                                Cada resultado começa por uma base bem construída. Na Bia Estética & Beleza, o primeiro atendimento funciona como um momento estratégico de observação e leitura das necessidades da cliente, criando o ponto de partida ideal para um cuidado mais assertivo.\n                            </p>\n                        </div>\n\n                        <!-- I -->\n                        <div class=\"group border-t border-[#2A3B34]/10 pt-10 gs-reveal-up\">\n                            <div class=\"flex items-baseline gap-6 mb-6\">\n                                <span class=\"font-display text-5xl md:text-7xl text-[#B99452] font-light leading-none\">I.</span>\n                                <h3 class=\"font-display text-2xl md:text-3xl text-[#2A3B34] font-normal tracking-tight\">Individualização Inteligente</h3>\n                            </div>\n                            <p class=\"font-sans text-lg font-light leading-relaxed text-[#2A3B34]/70\">\n                                Cada pele, cada corpo e cada objetivo pedem um olhar único. Por isso, os protocolos são pensados de forma personalizada, respeitando a individualidade da cliente e indicando o que realmente faz sentido para sua evolução.\n                            </p>\n                        </div>\n\n                        <!-- A -->\n                        <div class=\"group border-t border-[#2A3B34]/10 pt-10 gs-reveal-up\">\n                            <div class=\"flex items-baseline gap-6 mb-6\">\n                                <span class=\"font-display text-5xl md:text-7xl text-[#5C8A79] font-light leading-none\">A.</span>\n                                <h3 class=\"font-display text-2xl md:text-3xl text-[#2A3B34] font-normal tracking-tight\">Acompanhamento Ativo</h3>\n                            </div>\n                            <p class=\"font-sans text-lg font-light leading-relaxed text-[#2A3B34]/70\">\n                                O cuidado continua além da sessão. A cliente é acompanhada em sua evolução, recebe direcionamento sobre próximos passos e vive uma experiência mais segura, próxima e eficiente ao longo do tempo.\n                            </p>\n                        </div>\n                        \n                        <!-- Highlight Conclusion -->\n                        <div class=\"bg-[#2A3B34] rounded-[2rem] p-8 md:p-12 mt-8 gs-reveal-up shadow-xl\">\n                            <p class=\"font-display text-2xl md:text-3xl text-[#EFE4D9] font-light leading-snug\">\n                                Sua beleza merece mais do que uma sessão. <span class=\"text-[#DDA7A5] italic\">Merece método, sensibilidade e acompanhamento.</span>\n                            </p>\n                        </div>\n\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!-- Sobre a Bia Estética -->\n        <section id=\"sobre\" class=\"bg-[#2A3B34] text-[#EFE4D9] px-4 md:px-12 lg:px-24 py-32 md:py-40 rounded-[3rem] relative z-20 shadow-[0_-20px_50px_rgba(0,0,0,0.1)] overflow-hidden mx-2 lg:mx-8\">\n            <div class=\"absolute inset-0 opacity-10 bg-[url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E')] mix-blend-overlay\"></div>\n            \n            <div class=\"max-w-7xl mx-auto relative z-10 flex flex-col items-start gap-12 md:gap-16\">\n                <span class=\"font-mono text-xs uppercase tracking-tight text-[#DDA7A5] border border-[#DDA7A5]/30 px-5 py-2.5 rounded-full\">Sobre a Bia Estética & Beleza</span>\n                \n                <h2 class=\"font-display text-4xl md:text-5xl lg:text-6xl tracking-tight leading-[1.05] font-light gs-reveal-up max-w-5xl\">\n                    <span class=\"opacity-40\">Realce sua beleza com Bia.</span><br>\n                    Mais de 20 anos unindo experiência prática, cuidado humanizado e evolução constante.\n                </h2>\n                \n                <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 w-full mt-8 border-t border-[#EFE4D9]/10 pt-16\">\n                    \n                    <div class=\"lg:col-span-5 gs-reveal-up\" style=\"transition-delay: 100ms;\">\n                        <div class=\"w-full aspect-[4/5] rounded-[2rem] overflow-hidden relative shadow-2xl\">\n                            <img src=\"https://images.unsplash.com/photo-1556228578-0d85b1a4d571?q=80&w=1974&auto=format&fit=crop\" class=\"w-full h-full object-cover grayscale mix-blend-luminosity opacity-80 transition-transform duration-1000 hover:scale-105\" alt=\"Beatriz Teixeira - Estética e Beleza\">\n                            <div class=\"absolute inset-0 bg-[#2A3B34]/10 mix-blend-multiply\"></div>\n                        </div>\n                    </div>\n                    \n                    <div class=\"lg:col-span-7 flex flex-col justify-center gap-8 gs-reveal-up\" style=\"transition-delay: 200ms;\">\n                        <p class=\"font-sans text-xl md:text-2xl font-light leading-relaxed text-[#EFE4D9]/80\">\n                            Beatriz de Souza Lopes Teixeira atua na área da estética há mais de 20 anos. É Técnica em Estética desde 1993, Tecnóloga em Estética desde 2017 e atualmente está cursando Biomedicina, reforçando seu compromisso com atualização, excelência e atendimento qualificado.\n                        </p>\n                        <p class=\"font-sans text-xl md:text-2xl font-light leading-relaxed text-[#EFE4D9]/80\">\n                            À frente da Bia Estética & Beleza, em São Gonçalo/RJ, Beatriz desenvolveu o Método B.I.A. — Base, Individualização e Acompanhamento, uma forma própria de conduzir o cuidado estético com mais estratégia, personalização e continuidade.\n                        </p>\n                        <p class=\"font-sans text-xl md:text-2xl font-light leading-relaxed text-[#EFE4D9]/80\">\n                            Sua proposta vai além da realização de procedimentos. O objetivo é compreender cada cliente de forma individual, construir uma base consistente de cuidado e acompanhar sua evolução com sensibilidade, critério e atenção aos detalhes.\n                        </p>\n                        \n                        <div class=\"mt-8 border-l-2 border-[#DDA7A5] pl-6 py-2\">\n                            <span class=\"font-display text-2xl text-[#EFE4D9] font-normal tracking-tight\">Beatriz Teixeira</span>\n                            <span class=\"block font-mono text-xs uppercase tracking-widest text-[#DDA7A5] mt-2\">Fundadora & Especialista</span>\n                        </div>\n                    </div>\n\n                </div>\n            </div>\n        </section>\n\n        <!-- Protocol (Sticky Stack) -->\n        <section id=\"servicos\" class=\"bg-[#EFE4D9] py-24 md:py-32 relative z-30 rounded-t-[3rem] -mt-12 shadow-[0_-20px_50px_rgba(0,0,0,0.05)]\">\n            <div class=\"max-w-7xl mx-auto px-4 md:px-12 lg:px-24 mb-20 gs-reveal\">\n                <span class=\"font-mono text-xs uppercase tracking-tight text-[#5C8A79] mb-6 block\">Especialidades</span>\n                <h2 class=\"font-display text-5xl md:text-6xl lg:text-7xl tracking-tight leading-[0.9] text-[#2A3B34] font-normal\">Protocolos de<br>Cuidado.</h2>\n            </div>\n\n            <div class=\"relative w-full px-4 md:px-12 lg:px-24 max-w-7xl mx-auto\" id=\"stack-container\">\n                \n                <!-- Card 1: Facial -->\n                <div class=\"sticky top-24 pt-8 pb-8 md:h-[calc(100vh-6rem)] w-full flex items-center justify-center stack-card\">\n                    <div class=\"w-full h-full md:max-h-[700px] bg-white rounded-[2.5rem] shadow-[0_20px_60px_rgba(0,0,0,0.03)] bor