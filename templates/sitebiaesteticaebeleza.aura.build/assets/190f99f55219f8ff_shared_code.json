 ease: \"power3.out\" } });\n        \n        heroTl.to('.hero-img', { scale: 1.05, duration: 2.5, ease: \"power2.out\" }, 0)\n              .to('.hero-brand', { opacity: 1, y: 0, duration: 1 }, 0.5)\n              .to('.hero-headline', { opacity: 1, y: 0, duration: 1.2 }, 0.6)\n              .to('.hero-cta', { opacity: 1, y: 0, duration: 0.8 }, 1)\n              .to('.hero-link', { opacity: 1, x: 0, duration: 0.8, stagger: 0.1 }, 0.8)\n              .to('.hero-huge-text', { opacity: 1, y: 0, duration: 1.5, ease: \"expo.out\" }, 0.9);\n\n        // Parallax / Reveal fade out effect on scroll\n        gsap.to('.hero-content-inner', {\n            y: -100,\n            opacity: 0.3,\n            scrollTrigger: {\n                trigger: '.content-wrapper',\n                start: \"top 100%\", \n                end: \"top 0%\",     \n                scrub: true\n            }\n        });\n\n        // Basic Fade-Up Reveals\n        gsap.utils.toArray('.gs-reveal').forEach(function(elem) {\n            gsap.fromTo(elem, \n                { y: 40, opacity: 0 }, \n                { \n                    y: 0, \n                    opacity: 1, \n                    duration: 1.2, \n                    ease: \"power3.out\",\n                    scrollTrigger: {\n                        trigger: elem,\n                        start: \"top 85%\", \n                    }\n                }\n            );\n        });\n\n        // Tighter Fade-Up Reveals\n        gsap.utils.toArray('.gs-reveal-up').forEach(function(elem) {\n            gsap.fromTo(elem, \n                { y: 50, opacity: 0 }, \n                { \n                    y: 0, \n                    opacity: 1, \n                    duration: 1.2, \n                    ease: \"expo.out\",\n                    scrollTrigger: {\n                        trigger: elem,\n                        start: \"top 90%\", \n                    }\n                }\n            );\n        });\n\n        // Sticky Stack Protocol Effect\n        const stackCards = gsap.utils.toArray('.stack-card');\n        stackCards.forEach((card, i) => {\n            if (i !== stackCards.length - 1) {\n                const inner = card.querySelector('div');\n                gsap.to(inner, {\n                    scale: 0.92,\n                    opacity: 0.5,\n                    filter: \"blur(4px)\",\n                    scrollTrigger: {\n                        trigger: card,\n                        start: \"top 96px\", \n                        endTrigger: stackCards[i + 1],\n                        end: \"top 96px\",\n                        scrub: true,\n                    }\n                });\n            }\n        });\n\n    </script>\n</body>\n</html>","language":"html","username":"ef000661-c4cf-4988-b360-c14da3ddec96","created_at":"2026-03-21T01:20:18.049379+00:00","views":437,"image_url":"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/preview-images/sitebiaesteticaebeleza.png","forks":11,"private":false,"watermark":true,"featured":true,"share_source_code":true,"user_id":"ef000661-c4cf-4988-b360-c14da3ddec96","category":"Web","updated_at":null,"tags":["Landing Page","Services","Health","Brand","Dark","Minimal","Clean","Beauty","Wellness","Spa"],"description":"A reusable landing page template for beauty clinics and esthetic professionals to showcase treatments, care plans, credentials, and booking CTAs.","premium":false,"price":null,"purchase_url":null,"long_description":"## **Beauty clinic template**\nA sophisticated **landing page template** for esthetic clinics, beauty studios, and wellness brands that want to present services with credibility, elegance, and strong conversion paths.\n\n- Cinematic hero section with prominent booking CTA\n- Service showcases for facial, body, laser hair removal, and beauty treatments\n- Brand story and founder credentials section for trust-building\n- Care plan or package cards to promote memberships and bundled offers\n- WhatsApp-focused contact flow for fast appointment scheduling\n\n**Primary use case:** promoting local beauty and aesthetic services while guiding visitors toward consultation booking.\n\n## **Why it works**\n- Premium dark-to-light visual storytelling\n- Clear service segmentation and package positioning\n- Ideal for solo specialists or boutique clinics\n- Built to highlight expertise, personalization, and ongoing care","custom_domain":null,"favicon_light_url":null,"favicon_dark_url":null,"dns_verified":null,"dns_verified_at":null,"dns_a_record":null,"netlify_apex_exists":null,"netlify_www_exists":null,"netlify_verified_at":null,"custom_domain_added_at":null,"netlify_site_id":null,"umami_website_id":null,"umami_share_id":null,"analytics_enabled":false,"gtm_container_id":null,"remix_source":{},"credit_remix_source":false,"search_visibility":"aura_and_custom_domain","llms_txt":null,"llms_txt_updated_at":null}]