[{"id":13105,"slug":"grynnerup-aesthetics","title":"Grynnerup Aesthetics","code":"<!DOCTYPE html>\n<html lang=\"da\" class=\"scroll-smooth\">\n<head>\n<script>\ntry{if(window.parent&&window.parent!==window){window.parent.promotekit_referral=\"1fd2949a-d22c-431b-92bf-02d4ad04ee24\";window.parent.document.cookie=\"promotekit_referral=1fd2949a-d22c-431b-92bf-02d4ad04ee24;path=/;domain=.aura.build;max-age=31536000\"}}catch(e){}\n</script>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Grynnerup Aesthetics | Kosmetisk Klinik</title>\n<script src=\"https://cdn.tailwindcss.com\"></script>\n<script src=\"https://unpkg.com/lucide@latest\"></script>\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&display=swap\" rel=\"stylesheet\">\n<script>\ntailwind.config = {\ntheme: {\nextend: {\ncolors: {\nbrand: {\n50: '#F4F6F3',\n100: '#E6EBE4',\n200: '#CFD8CC',\n300: '#A9B9A4',\n800: '#4A5D43',\n900: '#354330',\n},\nstone: {\n850: '#1c1917',\n}\n},\nfontFamily: {\nsans: ['Inter', 'sans-serif'],\nserif: ['Playfair Display', 'serif'],\n}\n}\n}\n}\n</script>\n<style>\nbody {\n-webkit-font-smoothing: antialiased;\n-moz-osx-font-smoothing: grayscale;\n}\n.text-balance {\ntext-wrap: balance;\n}\n/* Styling for at sikre EasyPractice knappen ser pæn ud hvis den loader */\n#terapeutbookingonlinebooking {\nz-index: 40 !important;\n}\n</style></head>\n<body class=\"bg-brand-50 text-stone-600 font-sans selection:bg-brand-200 selection:text-brand-900\">\n\n    <!-- Navigation -->\n    <nav class=\"fixed w-full z-50 top-0 transition-all duration-300 bg-white/80 backdrop-blur-md border-b border-brand-100/50\">\n        <div class=\"max-w-7xl mx-auto px-6 lg:px-12\">\n            <div class=\"flex justify-between items-center h-20\">\n                <!-- Mobile Menu Button -->\n                <div class=\"flex items-center md:hidden\">\n                    <button type=\"button\" class=\"text-stone-800 hover:text-brand-800 transition\" onclick=\"document.getElementById('mobile-menu').classList.toggle('hidden')\">\n                        <i data-lucide=\"menu\" class=\"w-6 h-6\"></i>\n                    </button>\n                </div>\n\n                <!-- Logo -->\n                <a href=\"#\" class=\"flex flex-col items-center group\">\n                    <span class=\"font-serif text-2xl tracking-wide text-brand-800 uppercase\">Grynnerup</span>\n                    <span class=\"font-sans text-[0.65rem] tracking-[0.25em] text-brand-900 uppercase mt-0.5 group-hover:tracking-[0.3em] transition-all duration-500\">Aesthetics</span>\n                </a>\n\n                <!-- Desktop Nav Links -->\n                <div class=\"hidden md:flex items-center gap-8\">\n                    <a href=\"#behandlinger\" class=\"text-sm font-medium text-stone-600 hover:text-brand-800 transition-colors\">Behandlinger</a>\n                    <a href=\"#om\" class=\"text-sm font-medium text-stone-600 hover:text-brand-800 transition-colors\">Om Klinikken</a>\n                    <a href=\"#priser\" class=\"text-sm font-medium text-stone-600 hover:text-brand-800 transition-colors\">Priser</a>\n                    <a href=\"#kontakt\" class=\"text-sm font-medium text-stone-600 hover:text-brand-800 transition-colors\">Kontakt</a>\n                    <!-- Opdateret link til booking system -->\n                    <a href=\"https://system.easypractice.net/book/grynnerup-aesthetics\" target=\"_blank\" class=\"bg-brand-800 text-white px-5 py-2.5 rounded-sm text-xs font-medium tracking-wide uppercase hover:bg-brand-900 transition-colors shadow-sm\">\n                        Book Tid\n                    </a>\n                </div>\n\n                <!-- Mobile Placeholder for balance -->\n                <div class=\"w-6 md:hidden\"></div>\n            </div>\n        </div>\n\n        <!-- Mobile Menu -->\n        <div id=\"mobile-menu\" class=\"hidden md:hidden bg-white border-t border-stone-100 absolute w-full\">\n            <div class=\"px-6 py-6 space-y-4 flex flex-col items-center\">\n                <a href=\"#behandlinger\" class=\"text-base font-medium text-stone-800\">Behandlinger</a>\n                <a href=\"#om\" class=\"text-base font-medium text-stone-800\">Om Klinikken</a>\n                <a href=\"#priser\" class=\"text-base font-medium text-stone-800\">Priser</a>\n                <a href=\"#kontakt\" class=\"text-base font-medium text-stone-800\">Kontakt</a>\n                <a href=\"https://system.easypractice.net/book/grynnerup-aesthetics\" target=\"_blank\" class=\"text-base font-medium text-brand-800\">Book Konsultation</a>\n            </div>\n        </div>\n    </nav>\n\n    <!-- Hero Section -->\n    <section class=\"relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden\">\n        <div class=\"max-w-7xl mx-auto px-6 lg:px-12 relative z-10\">\n            <div class=\"grid lg:grid-cols-2 gap-12 lg:gap-20 items-center\">\n                <div class=\"order-2 lg:order-1 space-y-8\">\n                    <div class=\"inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-100/50 border border-brand-200 text-brand-900 text-xs tracking-wide uppercase font-medium\">\n                        <span class=\"w-1.5 h-1.5 rounded-full bg-brand-800\"></span>\n                        Ny klinik i Aarhus N\n                    </div>\n                    <h1 class=\"text-4xl lg:text-6xl font-serif text-stone-900 leading-[1.1] tracking-tight text-balance\">\n                        Naturlig skønhed gennem <span class=\"text-brand-800 italic pr-1\">æstetisk</span> præcision\n                    </h1>\n                    <p class=\"text-lg lg:text-xl text-stone-500 font-light leading-relaxed max-w-lg text-balance\">\n                        Vi skaber resultater, der ikke ændrer hvem du er, men fremhæver den bedste version af dig selv. Specialiseret i botox, filler og hudforbedring.\n                    </p>\n                    <div class=\"flex flex-col sm:flex-row gap-4 pt-4\">\n                        <a href=\"https://system.easypractice.net/book/grynnerup-aesthetics\" target=\"_blank\" class=\"inline-flex justify-center items-center px-8 py-3.5 bg-brand-800 text-white text-sm font-medium tracking-wide uppercase hover:bg-brand-900 transition-all shadow-md hover:shadow-lg\">\n                            Book Konsultation\n                        </a>\n                        <a href=\"#behandlinger\" class=\"inline-flex justify-center items-center px-8 py-3.5 bg-white border border-stone-200 text-stone-800 text-sm font-medium tracking-wide uppercase hover:bg-stone-50 transition-colors\">\n                            Se Behandlinger\n                        </a>\n                    </div>\n                </div>\n                <div class=\"order-1 lg:order-2 relative\">\n                    <div class=\"aspect-[4/5] relative rounded-sm overflow-hidden\">\n                        <img src=\"https://images.unsplash.com/photo-1616394584738-fc6e612e71b9?q=80&w=2070&auto=format&fit=crop\" alt=\"Naturlig skønhed\" class=\"object-cover w-full h-full opacity-90 hover:scale-105 transition-transform duration-1000 ease-out\">\n                    </div>\n                    <div class=\"absolute -bottom-6 -left-6 w-32 h-32 bg-brand-100/30 rounded-full blur-2xl -z-10\"></div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Principles / Philosophy -->\n    <section class=\"py-20 lg:py-28 bg-white border-y border-stone-100/50\">\n        <div class=\"max-w-7xl mx-auto px-6 lg:px-12\">\n            <div class=\"text-center max-w-2xl mx-auto mb-16 lg:mb-24\">\n                <span class=\"text-xs font-medium tracking-[0.2em] text-stone-400 uppercase\">Filosofi</span>\n                <h2 class=\"mt-4 text-3xl lg:text-4xl font-serif text-stone-900 tracking-tight\">Vores tilgang til aesthetics</h2>\n            </div>\n\n            <div class=\"grid md:grid-cols-3 gap-12 lg:gap-16\">\n                <!-- Principle 1 -->\n                <div class=\"group\">\n                    <div class=\"w-12 h-12 flex items-center justify-center rounded-full bg-brand-50 text-brand-800 mb-6 group-hover:bg-brand-800 group-hover:text-white transition-colors duration-500\">\n                        <i data-lucide=\"scale\" class=\"w-6 h-6 stroke-[1.5]\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-medium text-stone-900 mb-3 tracking-tight\">Balance & Harmoni</h3>\n                    <p class=\"text-stone-500 font-light leading-relaxed\">\n                        Vi analyserer ansigtets proportioner for at skabe balance. Målet er aldrig at overbehandle, men at genoprette symmetri og ro i ansigtstrækkene.\n                    </p>\n                </div>\n\n                <!-- Principle 2 -->\n                <div class=\"group\">\n                    <div class=\"w-12 h-12 flex items-center justify-center rounded-full bg-brand-50 text-brand-800 mb-6 group-hover:bg-brand-800 group-hover:text-white transition-colors duration-500\">\n                        <i data-lucide=\"scan-face\" class=\"w-6 h-6 stroke-[1.5]\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-medium text-stone-900 mb-3 tracking-tight\">Naturlig Præcision</h3>\n                    <p class=\"text-stone-500 font-light leading-relaxed\">\n                        Håndværket ligger i detaljen. Vi arbejder med diskrete justeringer, der giver et friskt og veludhvilet udtryk, uden at det ser 'lavet' ud.\n                    </p>\n                </div>\n\n                <!-- Principle 3 -->\n                <div class=\"group\">\n                    <div class=\"w-12 h-12 flex items-center justify-center rounded-full bg-brand-50 text-brand-800 mb-6 group-hover:bg-brand-800 group-hover:text-white transition-colors duration-500\">\n                        <i data-lucide=\"shield-check\" class=\"w-6 h-6 stroke-[1.5]\"></i>\n                    </div>\n                    <h3 class=\"text-xl font-medium text-stone-900 mb-3 tracking-tight\">Tryghed & Tillid</h3>\n                    <p class=\"text-stone-500 font-light leading-relaxed\">\n                        Din sikkerhed er fundamentet. Vi bruger kun de bedste produkter på markedet og sætter en ære i gennemsigtighed omkring forventninger og resultat.\n                    </p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Treatments Overview -->\n    <section id=\"behandlinger\" class=\"py-20 lg:py-28 bg-brand-50\">\n        <div class=\"max-w-7xl mx-auto px-6 lg:px-12\">\n            <div class=\"flex flex-col md:flex-row justify-between items-end mb-12 gap-6\">\n                <div class=\"max-w-xl\">\n                    <span class=\"text-xs font-medium tracking-[0.2em] text-stone-400 uppercase\">Behandlinger</span>\n                    <h2 class=\"mt-4 text-3xl lg:text-4xl font-serif text-stone-900 tracking-tight\">Ekspertise i injektioner</h2>\n                    <p class=\"mt-4 text-stone-500 font-light text-lg\">\n                        Vi fokuserer udelukkende på behandlinger, der kræver en sikker hånd og et æstetisk øje. Ingen maskiner, kun håndværk.\n                    </p>\n                </div>\n                <a href=\"#priser\" class=\"hidden md:inline-flex items-center text-sm font-medium text-brand-800 border-b border-brand-800/30 pb-0.5 hover:border-brand-800 transition-colors\">\n                    Se prisliste <i data-lucide=\"arrow-right\" class=\"w-4 h-4 ml-2\"></i>\n                </a>\n            </div>\n\n            <div class=\"grid md:grid-cols-3 gap-6 lg:gap-8\">\n                <!-- Card 1: Botox -->\n                <div class=\"bg-white group hover:shadow-xl transition-all duration-500 cursor-pointer rounded-sm overflow-hidden border border-stone-100\">\n                    <div class=\"aspect-[4/3] overflow-hidden\">\n                        <img src=\"https://images.unsplash.com/photo-1515377905703-c4788e51af15?q=80&w=2070&auto=format&fit=crop\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-700\" alt=\"Botox behandling\">\n                    </div>\n                    <div class=\"p-8\">\n                        <h3 class=\"text-2xl font-serif text-stone-900 mb-2\">Botox</h3>\n                        <p class=\"text-stone-500 font-light text-sm mb-6 leading-relaxed\">\n                            Effektiv reduktion af mimiske linjer. Vi bevarer din mimik og udtryk, men fjerner det 'strenge' eller trætte look. Perfekt til panderynker, smilerynker og brynløft.\n                        </p>\n                        <ul class=\"space-y-2 mb-8\">\n                            <li class=\"flex items-center text-sm text-stone-600 font-light\"><i data-lucide=\"check\" class=\"w-4 h-4 mr-2 text-brand-800\"></i>Udglatter fine linjer</li>\n                            <li class=\"flex items-center text-sm text-stone-600 font-light\"><i data-lucide=\"check\" class=\"w-4 h-4 mr-2 text-brand-800\"></i>Forebyggende effekt</li>\n                        </ul>\n                        <span class=\"inline-block text-brand-800 text-sm font-medium border-b border-transparent group-hover:border-brand-800 transition-colors\">Læs mere om Botox</span>\n                    </div>\n                </div>\n\n                <!-- Card 2: Filler -->\n                <div class=\"bg-white group hover:shadow-xl transition-all duration-500 cursor-pointer rounded-sm overflow-hidden border border-stone-100\">\n                    <div class=\"aspect-[4/3] overflow-hidden\">\n                        <img src=\"https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?q=80&w=2070&auto=format&fit=crop\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-700\" alt=\"Filler behandling\">\n                    </div>\n                    <div class=\"p-8\">\n                        <h3 class=\"text-2xl font-serif text-stone-900 mb-2\">Non-permanent Filler</h3>\n                        <p class=\"text-stone-500 font-light text-sm mb-6 leading-relaxed\">\n                            Genskab tabt volumen eller definer ansigtets konturer. Vi bruger markedets sikreste fillers til læber, kindben, hage og kæbelinje med fokus på harmoni.\n                        </p>\n                        <ul class=\"space-y-2 mb-8\">\n                            <li class=\"flex items-center text-sm text-stone-600 font-light\"><i data-lucide=\"check\" class=\"w-4 h-4 mr-2 text-brand-800\"></i>Markering af konturer</li>\n                            <li class=\"flex items-center text-sm text-stone-600 font-light\"><i data-lucide=\"check\" class=\"w-4 h-4 mr-2 text-brand-800\"></i>Genskaber volumen</li>\n                        </ul>\n                        <span class=\"inline-block text-brand-800 text-sm font-medium border-b border-transparent group-hover:border-brand-800 transition-colors\">Læs mere om Filler</span>\n                    </div>\n                </div>\n\n                <!-- Card 3: Skinbooster -->\n                <div class=\"bg-white group hover:shadow-xl transition-all duration-500 cursor-pointer rounded-sm overflow-hidden border border-stone-100\">\n                    <div class=\"aspect-[4/3] overflow-hidden\">\n                        <img src=\"https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/917d6f93-fb36-439a-8c48-884b67b35381_1600w.jpg\" class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-700\" alt=\"Skinbooster behandling\">\n                    </div>\n                    <div class=\"p-8\">\n                        <h3 class=\"text-2xl font-serif text-stone-900 mb-2\">Skinboosters</h3>\n                        <p class=\"text-stone-500 font-light text-sm mb-6 leading-relaxed\">\n                            Den ultimative fugtbehandling indefra. Forbedrer hudens kvalitet, elasticitet og glød. Ideel til tør hud, fine linjer og acne-ar i ansigt, hals og hænder.\n                        </p>\n                        <ul class=\"space-y-2 mb-8\">\n                            <li class=\"flex items-center text-sm text-stone-600 font-light\"><i data-lucide=\"check\" class=\"w-4 h-4 mr-2 text-brand-800\"></i>Dyb hydrering</li>\n                            <li class=\"flex items-center text-sm text-stone-600 font-light\"><i data-lucide=\"check\" class=\"w-4 h-4 mr-2 text-brand-800\"></i>Naturlig glød</li>\n                        </ul>\n                        <span class=\"inline-block text-brand-800 text-sm font-medium border-b border-transparent group-hover:border-brand-800 transition-colors\">Læs mere om Skinbooster</span>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- The Process / About Teaser -->\n    <section id=\"om\" class=\"py-20 lg:py-28 bg-white overflow-hidden\">\n        <div class=\"max-w-7xl mx-auto px-6 lg:px-12\">\n            <div class=\"grid lg:grid-cols-2 gap-16 items-center\">\n                <div class=\"relative\">\n                    <div class=\"aspect-[3/4] bg-stone-100 rounded-sm overflow-hidden\">\n                         <img src=\"https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&q=80&w=2069\" alt=\"Klinikindehaver hos Grynnerup\" class=\"object-cover w-full h-full grayscale hover:grayscale-0 transition-all duration-700\">\n                    </div>\n                    <div class=\"absolute -bottom-8 -right-8 w-48 h-48 bg-brand-50 z-[-1]\"></div>\n                </div>\n                <div>\n                    <span class=\"text-xs font-medium tracking-[0.2em] text-stone-400 uppercase\">Om Klinikken</span>\n                    <h2 class=\"mt-4 text-3xl lg:text-4xl font-serif text-stone-900 tracking-tight mb-8\">Tryghed er fundamentet for et smukt resultat</h2>\n                    <p class=\"text-stone-500 font-light text-lg mb-6 leading-relaxed\">\n                        Hos Grynnerup Aesthetics møder du altid faglighed på højeste niveau. Vi tror på, at en grundig konsultation er nøglen til det bedste resultat.\n                    </p>\n                    <p class=\"text-stone-500 font-light text-lg mb-10 leading-relaxed\">\n                        Vi siger nej tak, hvis vi vurderer, at en behandling ikke vil gavne dit ansigts harmoni. Ærlighed og integritet kommer før alt andet.\n                    </p>\n\n                    <!-- Steps -->\n                    <div class=\"space-y-6\">\n                        <div class=\"flex gap-4\">\n                            <span class=\"flex-shrink-0 w-8 h-8 rounded-full border border-stone-200 flex items-center justify-center text-sm font-serif text-brand-800\">1</span>\n                            <div>\n                                <h4 class=\"font-medium text-stone-900\">Konsultation</h4>\n                                <p class=\"text-sm text-stone-500 font-light mt-1\">Vi gennemgår dine ønsker og lægger en personlig plan.</p>\n                            </div>\n                        </div>\n                        <div class=\"flex gap-4\">\n                            <span class=\"flex-shrink-0 w-8 h-8 rounded-full border border-stone-200 flex items-center justify-center text-sm font-serif text-brand-800\">2</span>\n                            <div>\n                                <h4 class=\"font-medium text-stone-900\">Behandling</h4>\n                                <p class=\"text-sm text-stone-500 font-light mt-1\">Udføres med præcision og ro i sterile, trygge rammer.</p>\n                            </div>\n                        </div>\n                        <div class=\"flex gap-4\">\n                            <span class=\"flex-shrink-0 w-8 h-8 rounded-full border border-stone-200 flex items-center justify-center text-sm font-serif text-brand-800\">3</span>\n                            <div>\n                                <h4 class=\"font-medium text-stone-900\">Opfølgning</h4>\n                                <p class=\"text-sm text-stone-500 font-light mt-1\">Vi sikrer os, at resultatet lever op til forventningerne.</p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- Pricing Section -->\n    <section id=\"priser\" class=\"py-20 lg:py-28 bg-brand-50\">\n        <div class=\"max-w-4xl mx-auto px-6 lg:px-12\">\n            <div class=\"text-center mb-16\">\n                <span class=\"text-xs font-medium tracking-[0.2em] text-stone-400 uppercase\">Investering</span>\n                <h2 class=\"mt-4 text-3xl lg:text-4xl font-serif text-stone-900 tracking-tight\">Vejledende Priser</h2>\n                <p class=\"mt-4 text-stone-500 font-light\">Endelig pris fastsættes altid ved din gratis forundersøgelse.</p>\n            </div>\n\n            <div class=\"bg-white rounded-sm shadow-sm border border-stone-100 overflow-hidden\">\n                <!-- Category Header -->\n                <div class=\"bg-brand-800/5 px-6 py-3 border-b border-brand-800/10\">\n                    <h3 class=\"text-sm font-medium text-brand-800 uppercase tracking-wider\">Botox</h3>\n                </div>\n                <div class=\"divide-y divide-stone-100\">\n                    <div class=\"flex justify-between items-center p-6 hover:bg-stone-50/50 transition-colors\">\n                        <div>\n                            <span class=\"block text-stone-900 font-medium\">1 område</span>\n                            <span class=\"block text-xs text-stone-400 font-light mt-1\">Fx bekymringsrynke eller smilerynker</span>\n                        </div>\n                        <span class=\"text-stone-900 font-medium\">1.200 DKK</span>\n                    </div>\n                    <div class=\"flex justify-between items-center p-6 hover:bg-stone-50/50 transition-colors\">\n                        <div>\n                            <span class=\"block text-stone-900 font-medium\">2 områder</span>\n                        </div>\n                        <span class=\"text-stone-900 font-medium\">2.000 DKK</span>\n                    </div>\n                    <div class=\"flex justify-between items-center p-6 hover:bg-stone-50/50 transition-colors\">\n                        <div>\n                            <span class=\"block text-stone-900 font-medium\">3 områder</span>\n                            <span class=\"block text-xs text-stone-400 font-light mt-1\">Full face løft</span>\n                        </div>\n                        <span class=\"text-stone-900 font-medium\">2.600 DKK</span>\n                    </div>\n                </div>\n\n                <!-- Category Header -->\n                <div class=\"bg-brand-800/5 px-6 py-3 border-y border-brand-800/10 mt-0\">\n                    <h3 class=\"text-sm font-medium text-brand-800 uppercase tracking-wider\">Filler (Juvéderm / Restylane)</h3>\n                </div>\n                <div class=\"divide-y divide-stone-100\">\n                    <div class=\"flex justify-between items-center p-6 hover:bg-stone-50/50 transition-colors\">\n                        <div>\n                            <span class=\"block text-stone-900 font-medium\">0,5 ml Filler</span>\n                            <span class=\"block text-xs text-stone-400 font-light mt-1\">Let læbeforstørrelse</span>\n                        </div>\n                        <span class=\"text-stone-900 font-medium\">1.200 DKK</span>\n                    </div>\n                    <div class=\"flex justify-between items-center p-6 hover:bg-stone-50/50 transition-colors\">\n                        <div>\n                            <span class=\"block text-stone-900 font-medium\">1,0 ml Filler</span>\n                            <span class=\"block text-xs text-stone-400 font-light mt-1\">Læber, kindben eller hage</span>\n                        </div>\n                        <span class=\"text-stone-900 font-medium\">1.800 DKK</span>\n                    </div>\n                    <div class=\"flex justify-between items-center p-6 hover:bg-stone-50/50 transition-colors\">\n                        <div>\n                            <span class=\"block text-stone-900 font-medium\">2,0 ml Filler</span>\n                            <span class=\"block text-xs text-stone-400 font-light mt-1\">Større volumen eller flere områder</span>\n                        </div>\n                        <span class=\"text-stone-900 font-medium\">2.400 DKK</span>\n                    </div>\n                </div>\n\n                 <!-- Category Header: Skinbooster -->\n                 <div class=\"bg-brand-800/5 px-6 py-3 border-y border-brand-800/10 mt-0\">\n                    <h3 class=\"text-sm font-medium text-brand-800 uppercase tracking-wider\">Skinbooster</h3>\n                </div>\n                <div class=\"divide-y divide-stone-100\">\n                    <div class=\"flex justify-between items-center p-6 hover:bg-stone-50/50 transition-colors\">\n                        <div>\n                            <span class=\"block text-stone-900 font-medium\">1 Skinbooster (2 ml)</span>\n                            <span class=\"block text-xs text-stone-400 font-light mt-1\">Dyb hydrering og glød</span>\n                        </div>\n                        <span class=\"text-stone-900 font-medium\">1.500 DKK</span>\n                    </div>\n                    <div class=\"flex justify-between items-center p-6 hover:bg-stone-50/50 transition-colors\">\n                        <div>\n                            <span class=\"block text-stone-900 font-medium\">Pakkeforløb (3 behandlinger)</span>\n                            <span class=\"block text-xs text-stone-400 font-light mt-1\">Optimalt resultat</span>\n                        </div>\n                        <span class=\"text-stone-900 font-medium\">4.000 DKK</span>\n                    </div>\n                </div>\n\n                <!-- Category Header: PRP Behandling -->\n                <div class=\"bg-brand-800/5 px-6 py-3 border-y border-brand-800/10 mt-0\">\n                    <h3 class=\"text-sm font-medium text-brand-800 uppercase tracking-wider\">PRP Behandling</h3>\n                </div>\n                <div class=\"divide-y divide-stone-100\">\n                    <div class=\"flex justify-between items-center p-6 hover:bg-stone-50/50 transition-colors\">\n                        <div>\n                            <span class=\"block text-stone-900 font-medium\">1 behandling</span>\n                            <span class=\"block text-xs text-stone-400 font-light mt-1\">Naturlig vækst og fornyelse</span>\n                        </div>\n                        <span class=\"text-stone-900 font-medium\">2.300 DKK</span>\n                    </div>\n                    <div class=\"flex justify-between items-center p-6 hover:bg-stone-50/50 transition-colors\">\n                        <div>\n                            <span class=\"block text-stone-900 font-medium\">Pakkeforløb (3 behandlinger)</span>\n                            <span class=\"block text-xs text-stone-400 font-light mt-1\">Anbefalet kurforløb</span>\n                        </div>\n                        <span class=\"text-stone-900 font-medium\">6.000 DKK</span>\n                    </div>\n                    <div class=\"flex justify-between items-center p-6 hover:bg-stone-50/50 transition-colors\">\n                        <div>\n                            <span class=\"block text-stone-900 font-medium\">Pakkeforløb (5 behandlinger)</span>\n                            <span class=\"block text-xs text-stone-400 font-light mt-1\">Det fulde behandlingsforløb</span>\n                        </div>\n                        <span class=\"text-stone-900 font-medium\">9.500 DKK</span>\n                    </div>\n                </div>\n\n                 <!-- Category Header -->\n                 <div class=\"bg-brand-800/5 px-6 py-3 border-y border-brand-800/10 mt-0\">\n                    <h3 class=\"text-sm font-medium text-brand-800 uppercase tracking-wider\">Konsultation</h3>\n                </div>\n                <div class=\"divide-y divide-stone-100\">\n                    <div class=\"flex justify-between items-center p-6 hover:bg-stone-50/50 transition-colors\">\n                        <div>\n                            <span class=\"block text-stone-900 font-medium\">Forundersøgelse</span>\n                            <span class=\"block text-xs text-stone-400 font-light mt-1\">Obligatorisk før første behandling</span>\n                        </div>\n                        <span class=\"text-brand-800 font-medium\">Gratis</span>\n                    </div>\n                </div>\n            </div>\n            \n            <div class=\"mt-8 text-center\">\n                 <a href=\"https://system.easypractice.net/book/grynnerup-aesthetics\" target=\"_blank\" class=\"inline-flex justify-center items-center px-8 py-3.5 bg-brand-800 text-white text-sm font-medium tracking-wide uppercase hover:bg-brand-900 transition-all shadow-md\">\n                    Book tid til behandling\n                </a>\n            </div>\n        </div>\n    </section>\n\n    <!-- FAQ Section -->\n    <section class=\"py-20 lg:py-28 bg-white\">\n        <div class=\"max-w-3xl mx-auto px-6 lg:px-12\">\n            <h2 class=\"text-3xl font-serif text-stone-900 tracking-tight mb-12 text-center\">Ofte stillede spørgsmål</h2>\n            \n            <div class=\"space-y-4\">\n                <details class=\"group border-b border-stone-100 pb-4\">\n                    <summary class=\"flex justify-between items-center cursor-pointer list-none py-2 text-lg font-medium text-stone-800\">\n                        <span>Gør det ondt at blive behandlet?</span>\n                        <span class=\"transition group-open:rotate-180\">\n                            <i data-lucide=\"chevron-down\" class=\"w-5 h-5 text-stone-400\"></i>\n                        </span>\n                    </summary>\n                    <div class=\"text-stone-500 font-light mt-3 leading-relaxed animate-fadeIn\">\n                        De fleste oplever kun et lille stik eller ubehag. Vores fillere indeholder lokalbedøvelse (Lidokain), og vi tilbyder bedøvelsescreme inden behandling, hvis du ønsker det. Din komfort er vores prioritet.\n                    </div>\n                </details>\n\n                <details class=\"group border-b border-stone-100 pb-4\">\n                    <summary class=\"flex justify-between items-center cursor-pointer list-none py-2 text-lg font-medium text-stone-800\">\n                        <span>Hvor længe holder resultatet?</span>\n                        <span class=\"transition group-open:rotate-180\">\n                            <i data-lucide=\"chevron-down\" class=\"w-5 h-5 text-stone-400\"></i>\n                        </span>\n                    </summary>\n                    <div class=\"text-stone-500 font-light mt-3 leading-relaxed\">\n                        Holdbarheden varierer fra person til person. Botox holder typisk 3-4 måneder, mens filler kan holde 6-12 måneder afhængig af område og produkt. Skinboosters kræver ofte et kurforløb for optimalt resultat.\n                    </div>\n                </details>\n\n                <details class=\"group border-b border-stone-100 pb-4\">\n                    <summary class=\"flex justify-between items-center cursor-pointer list-none py-2 text-lg font-medium text-stone-800\">\n                        <span>Kan jeg gå på arbejde lige efter?</span>\n                        <span class=\"transition group-open:rotate-180\">\n                            <i data-lucide=\"chevron-down\" class=\"w-5 h-5 text-stone-400\"></i>\n                        </span>\n                    </summary>\n                    <div class=\"text-stone-500 font-light mt-3 leading-relaxed\">\n                        Ja, de fleste behandlinger har ingen eller minimal 'downtime'. Du kan opleve let rødme eller små hævelser umiddelbart efter injektionen, men dette fortager sig hurtigt. Vi guider dig i, hvad du skal undgå det første døgn.\n                    </div>\n                </details>\n            </div>\n        </div>\n    </section>\n\n    <!-- Booking / Contact Section -->\n    <section id=\"book-section\" class=\"py-20 lg:py-28 bg-brand-900 text-white relative overflow-hidden\">\n        <!-- Background Pattern -->\n        <div class=\"absolute inset-0 opacity-10\" style=\"background-image: url('data:image/svg+xml,%3Csvg width=\\'60\\' height=\\'60\\' viewBox=\\'0 0 60 60\\' xmlns=\\'0 0 2000 2000\\'%3E%3Cpath d=\\'M54.627 0l.83.828-1.415 1.415-.828-.828-.828.828-1.415-1.415.828-.828-.828-.828 1.415-1.415.828.828.828-.828 1.415 1.415-.828.828zM22.485 0l.83.828-1.415 1.415-.828-.828-.828.828-1.415-1.415.828-.828-.828-.828 1.415-1.415.828.828.828-.828 1.415 1.415-.828.828zM0 22.485l.828.83-1.415 1.415-.828-.828-.828.828L-2.83 22.485l.828-.828-.828-.828 1.415-1.415.828.828.828-.828 1.415 1.415-.828.828zM0 54.627l.828.83-1.415 1.415-.828-.828-.828.828L-2.83 54.627l.828-.828-.828-.828 1.415-1.415.828.828.828-.828 1.415 1.415-.828.828zM54.627 60l.83.828-1.415 1.415-.828-.828-.828.828-1.415-1.415.828-.828-.828-.828 1.415-1.415.828.828.828-.828 1.415 1.415-.828.828zM22.485 60l.83.828-1.415 1.415-.828-.828-.828.828-1.415-1.415.828-.828-.828-.828 1.415-1.415.828.828.828-.828 1.415 1.415-.828.828z\\' fill=\\'%23ffffff\\' fill-opacity=\\'1\\' fill-rule=\\'evenodd\\'/%3E%3C/svg%3E');\"></div>\n        \n        <div class=\"max-w-7xl mx-auto px-6 lg:px-12 relative z-10\">\n            <div class=\"grid lg:grid-cols-2 gap-16 lg:gap-24\">\n                <div>\n                    <span class=\"text-brand-300 text-xs font-medium tracking-[0.2em] uppercase\">Start rejsen</span>\n                    <h2 class=\"mt-4 text-3xl lg:text-5xl font-serif text-white tracking-tight mb-6\">Klar til at fremhæve det bedste ved dig selv?</h2>\n                    <p class=\"text-brand-100 font-light text-lg mb-8 max-w-md leading-relaxed\">\n                        Book en uforpligtende konsultation i dag. Vi tager os tid til at lytte, analysere og lægge en plan, der passer præcis til dig.\n                    </p>\n                    <a href=\"https://system.easypractice.net/book/grynnerup-aesthetics\" target=\"_blank\" class=\"inline-block bg-white text-brand-900 px-8 py-4 rounded-sm text-sm font-medium tracking-wide uppercase hover:bg-brand-50 transition-colors shadow-lg\">\n                        Book Online Nu\n                    </a>\n                    <p class=\"mt-6 text-sm text-brand-300 flex items-center gap-2\">\n                        <i data-lucide=\"check-circle\" class=\"w-4 h-4\"></i> Gratis forundersøgelse\n                    </p>\n                </div>\n\n                <div id=\"kontakt\" class=\"bg-brand-800/50 backdrop-blur-sm p-8 lg:p-12 border border-brand-700/50 rounded-sm\">\n                    <h3 class=\"text-2xl font-serif mb-6 text-white\">Kontakt & Åbningstider</h3>\n                    <div class=\"space-y-6\">\n                        <div class=\"flex items-start gap-4\">\n                            <i data-lucide=\"map-pin\" class=\"w-5 h-5 text-brand-300 mt-1\"></i>\n                            <div>\n                                <p class=\"font-medium text-white\">Grynnerup Aesthetics</p>\n                                <p class=\"text-brand-200 font-light text-sm\">Ringgade 117<b