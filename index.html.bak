                    <form id="cta-form" novalidate>
                        <label for="cta-input" class="sr-only">O que você quer melhorar em você</label>
                        <div class="cta-field">
                            <textarea id="cta-input" name="mensagem" maxlength="600"
                                placeholder="Digite aqui o que você quer melhorar em você"
                                aria-describedby="cta-privacy"></textarea>
                            <span class="cta-char" id="cta-char" aria-hidden="true">0 / 600</span>
                        </div>

                        <button type="submit" class="btn btn-solar cta-submit" id="cta-submit" disabled>
                            <span class="btn-spinner" aria-hidden="true"></span>
                            <span class="cta-submit__label">Sugerir meu plano</span>
                            <iconify-icon class="ico" icon="solar:magic-stick-3-bold" width="18"></iconify-icon>
                        </button>

                        <p class="cta-privacy" id="cta-privacy">
                            <iconify-icon icon="solar:lock-keyhole-minimalistic-bold" width="14"></iconify-icon>
                            Suas informações ficam entre você e a nossa equipe. Nada de spam.
                        </p>
                    </form>

                    <!-- resultado gerado pela IA -->
                    <div class="cta-plan" id="cta-plan" role="region" aria-live="polite" aria-label="Plano sugerido">
