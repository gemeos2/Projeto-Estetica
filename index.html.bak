                            </p>
                            <a href="#contato" class="btn btn-solar py-2.5 px-6 text-sm" id="cta-plan-cta">
                                Agendar avaliação
                                <iconify-icon class="ico" icon="solar:arrow-right-linear" width="16"></iconify-icon>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- coluna direita: vídeo do interior do espaço -->
                <div class="cta-video" id="cta-video" data-reveal data-reveal-delay="1">
